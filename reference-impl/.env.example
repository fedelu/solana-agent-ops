# Solana Agent Ops — reference bot config. Copy to .env. PUBLIC VALUES ONLY.
# A real deployment loads the signer secret from KMS/secrets-manager by reference (see keypair-fleet.md),
# NOT from a plaintext file. For devnet convenience this reference generates+persists a dev keypair
# under .state/ (gitignored) when AGENT_SECRET is unset.

# Cluster + RPC (vendor-neutral; swap in your provider's URL)
CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com

# Safety: start in dry-run. Set to false to actually send.
DRY_RUN=true

# The demo action: self-transfer this many lamports (proves the full landing pipeline cheaply)
AMOUNT_LAMPORTS=1000

# Spend caps (lamports). The most restrictive wins; enforced before every send.
CAP_PER_TX=100000
CAP_PER_CYCLE=200000
CAP_PER_DAY=2000000

# Max total priority fee per tx (lamports)
CAP_MAX_FEE=50000

# Funding: top up below threshold, target refill (devnet uses airdrop)
FUND_THRESHOLD_LAMPORTS=50000000
FUND_TOPUP_TO_LAMPORTS=200000000

# Optional: load signer from a base58 secret or JSON byte array instead of the generated dev key.
# AGENT_SECRET=

# Optional: ntfy topic for alerts (leave blank to log-only)
# NTFY_TOPIC=
